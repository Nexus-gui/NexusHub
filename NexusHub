local function YJEMIB_fake_script() -- MusicList.dragdelay1 
	local script = Instance.new('LocalScript', MusicList)

	local frame = script.Parent
	local UserInputService = game:GetService("UserInputService")
	local TweenService = game:GetService("TweenService")
	
	local dragging = false
	local dragStart = nil
	local startPos = nil
	local dragDelayActive = false
	local dragTween = nil
	
	local function update(input)
	    if not dragging then return end
	    local delta = input.Position - dragStart
	    local targetPos = UDim2.new(
	        startPos.X.Scale,
	        startPos.X.Offset + delta.X,
	        startPos.Y.Scale,
	        startPos.Y.Offset + delta.Y
	    )
	    if dragTween then
	        dragTween:Cancel()
	    end
	    dragTween = TweenService:Create(frame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = targetPos})
	    dragTween:Play()
	end
	
	frame.InputBegan:Connect(function(input)
	    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
	        if not dragging and not dragDelayActive then
	            dragDelayActive = true
	            dragStart = input.Position
	            startPos = frame.Position
	            -- Wait for 0.5 seconds before starting drag
	            task.wait(0.5)
	            dragging = true
	            dragDelayActive = false
	        end
	    end
	end)
	
	frame.InputEnded:Connect(function(input)
	    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
	        dragging = false
	        dragDelayActive = false
	        if dragTween then
	            dragTween:Cancel()
	            dragTween = nil
	        end
	    end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
	    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
	        update(input)
	    end
	end)
	
	
end
coroutine.wrap(YJEMIB_fake_script)()
local function QNZNG_fake_script() -- MusicList.MusicPlayerScript 
	local script = Instance.new('LocalScript', MusicList)

	local Players = game:GetService("Players")
	local SoundService = game:GetService("SoundService")
	
	local player = Players.LocalPlayer
	local playerGui = player:WaitForChild("PlayerGui")
	
	-- Wait for the GUI to load
	local adminUi = playerGui:WaitForChild("AdminUiV3")
	local mainFrame = adminUi:WaitForChild("MainFrame")
	local secondaryFrame = mainFrame:WaitForChild("Secondaryframe")
	
	-- Get UI elements
	local musicPlayerButton = secondaryFrame:WaitForChild("MusicPlayer")
	local musicList = adminUi:WaitForChild("MusicList")
	local entersoundid = musicList:WaitForChild("entersoundid")
	local musicvalidater = musicList:WaitForChild("Musicvalidater")
	local playMusicButton = musicList:WaitForChild("PlayMusic")
	local stopMusicButton = musicList:WaitForChild("StopMusic")
	
	-- Track currently playing sounds
	local playingSounds = {}
	
	-- Toggle MusicList visibility when MusicPlayer button is clicked
	musicPlayerButton.MouseButton1Click:Connect(function()
	    local isVisible = musicList.Visible
	    musicList.Visible = not isVisible
	    
	    -- Make all children visible when MusicList is shown
	    if musicList.Visible then
	        for _, child in ipairs(musicList:GetDescendants()) do
	            if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("Frame") or child:IsA("ImageButton") or child:IsA("ImageLabel") then
	                child.Visible = true
	            end
	        end
	    end
	end)
	
	-- Validate sound ID when text changes
	entersoundid:GetPropertyChangedSignal("Text"):Connect(function()
	    local soundId = entersoundid.Text
	    
	    -- Skip if empty
	    if soundId == "" then
	        musicvalidater.BackgroundColor3 = Color3.fromRGB(128, 128, 128) -- Gray for neutral
	        return
	    end
	    
	    -- Create a temporary sound to validate
	    local testSound = Instance.new("Sound")
	    testSound.SoundId = "rbxassetid://" .. soundId
	    testSound.Parent = SoundService
	    
	    -- Wait a moment for the sound to load
	    task.wait(0.5)
	    
	    -- Check if the sound is valid by checking if it loaded properly
	    local success, length = pcall(function()
	        return testSound.TimeLength
	    end)
	    
	    if success and length > 0 then
	        musicvalidater.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- Green for valid
	    else
	        -- Give it another chance to load
	        task.wait(1)
	        success, length = pcall(function()
	            return testSound.TimeLength
	        end)
	        
	        if success and length > 0 then
	            musicvalidater.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- Green for valid
	        else
	            musicvalidater.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Red for invalid
	        end
	    end
	    
	    -- Clean up test sound
	    testSound:Destroy()
	end)
	
	-- Play music when PlayMusic button is clicked
	playMusicButton.MouseButton1Click:Connect(function()
	    local soundId = entersoundid.Text
	    
	    if soundId == "" then
	        return
	    end
	    
	    -- Create and play the sound
	    local sound = Instance.new("Sound")
	    sound.SoundId = "rbxassetid://" .. soundId
	    sound.Looped = false
	    sound.Volume = 1
	    sound.Parent = SoundService
	    
	    -- Track this sound
	    table.insert(playingSounds, sound)
	    
	    -- Play the sound
	    sound:Play()
	    
	    -- Remove from tracking when sound ends
	    sound.Ended:Connect(function()
	        for i, s in ipairs(playingSounds) do
	            if s == sound then
	                table.remove(playingSounds, i)
	                break
	            end
	        end
	        sound:Destroy()
	    end)
	end)
	
	-- Stop all music when StopMusic button is clicked
	stopMusicButton.MouseButton1Click:Connect(function()
	    -- Stop and destroy all tracked sounds
	    for i, sound in ipairs(playingSounds) do
	        sound:Stop()
	        sound:Destroy()
	    end
	    playingSounds = {}
	    
	    -- Also stop any other sounds in SoundService
	    for _, sound in ipairs(SoundService:GetChildren()) do
	        if sound:IsA("Sound") then
	            sound:Stop()
	            sound:Destroy()
	        end
	    end
	end)
end
