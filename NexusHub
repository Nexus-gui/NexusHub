local function KIELZMS_fake_script() -- fly.FlyButtonScript 
	local script = Instance.new('LocalScript', fly)

	local button = script.Parent
	local Players = game:GetService("Players")
	local UserInputService = game:GetService("UserInputService")
	local flying = false
	local speed = 50 -- studs per second
	local moveDirection = Vector3.new(0, 0, 0)
	local bodyVelocity = nil
	
	local function setGravity(enabled)
	    local player = Players.LocalPlayer
	    local character = player.Character
	    if character then
	        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	        if humanoidRootPart then
	            humanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
	            humanoidRootPart.CanCollide = not enabled
	        end
	        local humanoid = character:FindFirstChildOfClass("Humanoid")
	        if humanoid then
	            humanoid.PlatformStand = enabled
	        end
	    end
	end
	
	local function startFlying()
	    setGravity(true)
	    local player = Players.LocalPlayer
	    local character = player.Character
	    if character then
	        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	        if humanoidRootPart then
	            bodyVelocity = Instance.new("BodyVelocity")
	            bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
	            bodyVelocity.Velocity = Vector3.new(0, 0, 0)
	            bodyVelocity.Parent = humanoidRootPart
	        end
	    end
	end
	
	local function stopFlying()
	    setGravity(false)
	    local player = Players.LocalPlayer
	    local character = player.Character
	    if character then
	        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	        if humanoidRootPart and bodyVelocity then
	            bodyVelocity:Destroy()
	            bodyVelocity = nil
	        end
	    end
	    moveDirection = Vector3.new(0, 0, 0)
	end
	
	button.MouseButton1Click:Connect(function()
	    flying = not flying
	    if flying then
	        startFlying()
	    else
	        stopFlying()
	    end
	end)
	
	UserInputService.InputBegan:Connect(function(input, processed)
	    if not flying or processed then return end
	    if input.KeyCode == Enum.KeyCode.W then
	        moveDirection = Vector3.new(moveDirection.X, moveDirection.Y, 1) -- FIXED: W is forward
	    elseif input.KeyCode == Enum.KeyCode.S then
	        moveDirection = Vector3.new(moveDirection.X, moveDirection.Y, -1) -- FIXED: S is backward
	    elseif input.KeyCode == Enum.KeyCode.A then
	        moveDirection = Vector3.new(-1, moveDirection.Y, moveDirection.Z)
	    elseif input.KeyCode == Enum.KeyCode.D then
	        moveDirection = Vector3.new(1, moveDirection.Y, moveDirection.Z)
	    elseif input.KeyCode == Enum.KeyCode.Space then
	        moveDirection = Vector3.new(moveDirection.X, 1, moveDirection.Z)
	    elseif input.KeyCode == Enum.KeyCode.LeftShift then
	        moveDirection = Vector3.new(moveDirection.X, -1, moveDirection.Z)
	    end
	end)
	
	UserInputService.InputEnded:Connect(function(input, processed)
	    if not flying then return end
	    if input.KeyCode == Enum.KeyCode.W or input.KeyCode == Enum.KeyCode.S then
	        moveDirection = Vector3.new(moveDirection.X, moveDirection.Y, 0)
	    elseif input.KeyCode == Enum.KeyCode.A or input.KeyCode == Enum.KeyCode.D then
	        moveDirection = Vector3.new(0, moveDirection.Y, moveDirection.Z)
	    elseif input.KeyCode == Enum.KeyCode.Space or input.KeyCode == Enum.KeyCode.LeftShift then
	        moveDirection = Vector3.new(moveDirection.X, 0, moveDirection.Z)
	    end
	end)
	
	game:GetService("RunService").RenderStepped:Connect(function()
	    if flying and bodyVelocity then
	        local player = Players.LocalPlayer
	        local character = player.Character
	        if character then
	            local camera = workspace.CurrentCamera
	            local camCF = camera.CFrame
	            local forward = camCF.LookVector
	            local right = camCF.RightVector
	            local up = Vector3.new(0, 1, 0)
	            local velocity = Vector3.new(0, 0, 0)
	            velocity = velocity + forward * moveDirection.Z
	            velocity = velocity + right * moveDirection.X
	            velocity = velocity + up * moveDirection.Y
	            if velocity.Magnitude > 0 then
	                velocity = velocity.Unit * speed
	            end
	            bodyVelocity.Velocity = velocity
	        end
	    end
	end)
	
	
end
